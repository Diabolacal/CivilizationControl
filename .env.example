# CivilizationControl environment variables
# Copy to .env and fill in real values

# World package (Stillness testnet; informational, runtime IDs live in src/constants.ts)
VITE_EVE_WORLD_PACKAGE_ID="0x28b497559d65ab320d9da4613bf2498d5946b2c0ae3597ccfda3072ce127448c"

# Sui GraphQL endpoint
VITE_SUI_GRAPHQL_ENDPOINT="https://graphql.testnet.sui.io/graphql"

# Sponsor worker (gas sponsorship for governance PTBs)
# Leave blank to use normal wallet-paid execution.
# Local worker example: http://127.0.0.1:8787
VITE_SPONSOR_URL=

# Optional bearer header forwarded by the browser client.
# If set here, treat it as public browser-visible configuration, not a secret.
VITE_SPONSOR_API_KEY=

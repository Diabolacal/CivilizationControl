# CivilizationControl environment variables
# Copy to .env and fill in real values

# World package (Utopia testnet)
VITE_EVE_WORLD_PACKAGE_ID="0xd12a70c74c1e759445d6f209b01d43d860e97fcf2ef72ccbbd00afd828043f75"

# Sui GraphQL endpoint
VITE_SUI_GRAPHQL_ENDPOINT="https://graphql.testnet.sui.io/graphql"

# Sponsor worker (gas sponsorship for governance PTBs)
# URL is required to enable sponsorship; API key is optional (worker-side auth)
VITE_SPONSOR_URL=https://flappy-frontier-sponsor.michael-davis-home.workers.dev
VITE_SPONSOR_API_KEY=
